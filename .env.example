# === Mode: "local" (Jason PC + OpenAI) or "airgap" (closed network + GPT-OSS) ===
MODE=local

# === LLM Configuration ===
# Local: OpenAI API
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# Airgap: GPT-OSS 120B (uncomment below, comment above)
# LLM_API_BASE=http://localhost:8000/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=gpt-oss-120b

# === Embedding Model ===
EMBEDDING_MODEL_PATH=./models/embedding

# === ChromaDB ===
# Docker 사용 시: CHROMA_PORT=8100 (chromadb/chroma 컨테이너 필요)
# 폐쇄망/Docker 없을 때: CHROMA_PORT=0 (로컬 in-process 모드, Docker 불필요)
CHROMA_HOST=localhost
CHROMA_PORT=0

# === Database (Text-to-SQL) ===
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=1521
DB_NAME=ORCL
DB_USER=readonly_user
DB_PASSWORD=your-password

# === Function Calling ===
FUNCTION_CALLING_MODE=auto  # "native", "prompt", "auto"

# === Webhook / n8n ===
WEBHOOK_SECRET=
N8N_BASE_URL=http://n8n:5678

# === Multi-Modal (Level 10) ===
WHISPER_MODEL_PATH=./models/whisper
VISION_MODEL=  # e.g. gpt-4o for OpenAI, empty = disabled
OCR_ENGINE=paddleocr  # "paddleocr" or "tesseract"

# === Offline flags (airgap — uncomment when on closed network) ===
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
