# ============================================================
# 폐쇄망 (Airgap) 환경 설정
# 사용법: cp .env.airgap .env
# ============================================================

# === Mode ===
MODE=airgap

# === LLM Configuration (vLLM local) ===
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=mistral-7b

# === vLLM Configuration (docker-compose.vllm.yml에서 사용) ===
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_SERVED_NAME=mistral-7b
VLLM_MAX_MODEL_LEN=4096
VLLM_DTYPE=auto

# === Embedding Model (local, no internet) ===
EMBEDDING_MODEL_PATH=./models/embedding

# === ChromaDB ===
CHROMA_HOST=localhost
CHROMA_PORT=0

# === Database (Text-to-SQL) ===
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=1521
DB_NAME=XEPDB1
DB_USER=MESADMIN
DB_PASSWORD=mesadmin123

# === Offline flags ===
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
